{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://degodb.local/schemas/mtool/plugins/ai/domain.game-content/game-content-candidate.schema.json",
  "title": "Game Content Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plugin_id",
    "candidate_id",
    "game",
    "scenarios",
    "maps",
    "scenes",
    "characters",
    "runtime_handoff",
    "validation_notes",
    "non_goals"
  ],
  "properties": {
    "schema_version": {
      "const": "game_content_ai_candidate.v1"
    },
    "plugin_id": {
      "const": "domain.game-content"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "genre",
        "opening_scene_id"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "genre": {
          "type": "string",
          "minLength": 1
        },
        "opening_scene_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "maps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/map"
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/character"
      }
    },
    "runtime_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "mtool_owned",
        "external_runtime_owned",
        "forbidden_without_explicit_artifact"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "mtool_owned": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "external_runtime_owned": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_without_explicit_artifact": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "summary",
        "entry_scene_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "entry_scene_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "width",
        "height",
        "areas"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "areas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/map_area"
          }
        }
      }
    },
    "map_area": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "scene_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "scene_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "map_id",
        "summary",
        "transitions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "map_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "target_scene_id"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "target_scene_id": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string"
        }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "role",
        "base_status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "base_status": {
          "$ref": "#/$defs/status_block"
        }
      }
    },
    "status_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hp",
        "attack",
        "defense",
        "speed"
      ],
      "properties": {
        "hp": {
          "type": "integer",
          "minimum": 1
        },
        "attack": {
          "type": "integer",
          "minimum": 0
        },
        "defense": {
          "type": "integer",
          "minimum": 0
        },
        "speed": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
