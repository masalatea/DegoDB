{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://degodb.local/schemas/mtool/plugins/ai/domain.game-audio/game-audio-candidate.schema.json",
  "title": "Game Audio Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plugin_id",
    "candidate_id",
    "audio_profile",
    "music_cues",
    "sfx_cues",
    "trigger_map",
    "runtime_handoff",
    "validation_notes",
    "non_goals"
  ],
  "properties": {
    "schema_version": {
      "const": "game_audio_ai_candidate.v1"
    },
    "plugin_id": {
      "const": "domain.game-audio"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "audio_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "game_title",
        "style",
        "default_music_policy",
        "default_sfx_policy"
      ],
      "properties": {
        "game_title": {
          "type": "string",
          "minLength": 1
        },
        "style": {
          "type": "string",
          "minLength": 1
        },
        "default_music_policy": {
          "$ref": "#/$defs/music_policy"
        },
        "default_sfx_policy": {
          "$ref": "#/$defs/sfx_policy"
        }
      }
    },
    "music_cues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/music_cue"
      }
    },
    "sfx_cues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sfx_cue"
      }
    },
    "trigger_map": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "runtime_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "mtool_owned",
        "external_audio_runtime_owned",
        "forbidden_without_explicit_artifact"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "mtool_owned": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "external_audio_runtime_owned": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_without_explicit_artifact": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "music_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop",
        "fade_ms",
        "priority"
      ],
      "properties": {
        "loop": {
          "type": "boolean"
        },
        "fade_ms": {
          "type": "integer",
          "minimum": 0
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sfx_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_overlap",
        "default_volume"
      ],
      "properties": {
        "max_overlap": {
          "type": "integer",
          "minimum": 1
        },
        "default_volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "music_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "mood",
        "policy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "mood": {
          "type": "string",
          "minLength": 1
        },
        "policy": {
          "$ref": "#/$defs/music_policy"
        }
      }
    },
    "sfx_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "category",
        "policy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "policy": {
          "$ref": "#/$defs/sfx_policy"
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "source_ref",
        "cue_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "scene_enter_music",
            "event_sfx",
            "state_change_sfx"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "cue_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
