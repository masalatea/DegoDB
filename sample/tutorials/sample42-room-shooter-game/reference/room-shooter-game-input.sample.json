{
  "schema_version": "room_shooter_game_input.v1",
  "generated_by": {
    "tool": "mtool",
    "artifact": "room_shooter_game_input",
    "source_packets": [
      "shared_state_sync_server_input",
      "shared_state_sync_client_input"
    ]
  },
  "sample": "sample42-room-shooter-game",
  "contracts": {
    "shared_state_sync_contract": "docs/shared-state-sync-contract.md",
    "schema_api_contract": "docs/shared-state-sync-schema-api-contract.md",
    "realtime_contract": "docs/shared-state-sync-realtime-contract.md",
    "node_server_input_contract": "docs/shared-state-sync-node-server-input-packet.md",
    "client_input_contract": "docs/shared-state-sync-app-client-input-packet.md"
  },
  "runtime_boundary": {
    "owner": "external_game_runtime_owner",
    "mtool_responsibility": [
      "emit structured shared-state handoff packets",
      "emit domain-specific game state contract",
      "validate that the sample runtime consumes the contract"
    ],
    "external_runtime_responsibility": [
      "serve the game loop",
      "own anti-cheat decisions",
      "own production deployment",
      "own authentication and matchmaking"
    ],
    "production_runtime_generated": false
  },
  "shared_state_mapping": {
    "state_key": "game",
    "room_identifier": "url_room_slug",
    "revision_required": true,
    "fanout_scope": "room",
    "transport": {
      "primary": "sse_http",
      "event": "game.updated"
    }
  },
  "room_policy": {
    "max_players": 2,
    "room_slug_source": "url",
    "third_player_error": "room_full",
    "cross_room_broadcast_allowed": false
  },
  "game_rules": {
    "schema_version": "room_shooter_game.v2.local_bottom_duel",
    "arena": {
      "width": 900,
      "height": 560
    },
    "player_hp": 100,
    "shot_damage": 25,
    "shot_hit_radius": 32,
    "perspective": "local_player_bottom_opponent_top",
    "shot_direction": "local_player_upward",
    "projectile_tick": "server_side_interval",
    "commands": [
      "move",
      "shoot"
    ],
    "events": [
      "game.updated"
    ]
  },
  "state_model": {
    "entities": [
      "players",
      "shots"
    ],
    "player_fields": [
      "id",
      "hp",
      "x",
      "y",
      "facing",
      "joined_at"
    ],
    "shot_fields": [
      "id",
      "owner_id",
      "x",
      "y",
      "vx",
      "vy",
      "created_at"
    ],
    "winner_field": "winner"
  },
  "validation": {
    "required_checks": [
      "mtool_server_packet_can_be_emitted",
      "mtool_client_packet_can_be_emitted",
      "game_contract_matches_runtime_rules",
      "old_local_room_state_resets_when_runtime_rule_changes",
      "room_join_limit_matches_contract",
      "commands_match_contract",
      "event_name_matches_contract",
      "cross_room_broadcast_forbidden",
      "packet_contains_no_tokens_or_secrets"
    ]
  },
  "forbidden_actions": [
    "store_sso_tokens_in_game_packet",
    "broadcast_to_all_rooms",
    "claim_production_game_server_generation",
    "claim_matchmaking_or_anticheat_support"
  ]
}
