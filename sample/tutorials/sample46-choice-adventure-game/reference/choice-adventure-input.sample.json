      ]
    },
    {
      "id": "ending_bad",
      "kind": "game_over",
      "frame": "lost_pages",
      "title": "Game Over: Lost in the Index",
      "text": "The rain stops. Every sign now points to a shelf that was not there a moment ago.",
      "choices": [
        {
          "label": "Return to the previous scene",
          "target": "__back__"
        },
        {
          "label": "Restart from opening",
          "target": "opening"
        }
      ]
    }
