# Durable / team-use config DB settings.
#
# Copy this file to an untracked env file before use, for example:
#
#   cp deploy/durable-config-db.env.example .env.durable
#
# Then fill the values and run:
#
#   make up-durable-config-db DURABLE_ENV_FILE=.env.durable
#
# Do not commit populated secrets.

ADMIN_HTTP_PORT=8081
LAB_HTTP_PORT=8082
LAB_DB_HOST_PORT=33062
LAB_DB_UI_HTTP_PORT=8083

APP_GENERATED_DBCLASSES_MODE=legacy-copy-bootstrap
APP_PROJECT_REPOSITORY_DRIVER=pdo
APP_EXPERIMENT_REPOSITORY_DRIVER=pdo
APP_TRANSLATION_PROVIDER=disabled
APP_TRANSLATION_GOOGLE_API_KEY=
APP_TRANSLATION_TIMEOUT_SECONDS=10

ADMIN_SESSION_NAME=MTOOL_ADMIN_SESSID
ADMIN_AUTH_MODE=stub
ADMIN_AUTH_STUB_USER=admin-local
ADMIN_AUTH_STUB_PASSWORD=change-this-admin-password
ADMIN_AUTH_STUB_NAME=AdminLocalUser
ADMIN_AUTH_STUB_ROLES=admin,config

LAB_SESSION_NAME=MTOOL_LAB_SESSID
LAB_AUTH_MODE=stub
LAB_AUTH_STUB_USER=lab-local
LAB_AUTH_STUB_PASSWORD=change-this-lab-password
LAB_AUTH_STUB_NAME=LabLocalUser
LAB_AUTH_STUB_ROLES=lab

# Durable canonical metadata store.
# Use a managed MariaDB/MySQL instance or another backed-up DB host.
APP_CONFIG_DB_HOST=external-db.example
APP_CONFIG_DB_PORT=3306
APP_CONFIG_DB_NAME=config_app
APP_CONFIG_DB_USER=config_app
APP_CONFIG_DB_PASSWORD=change-this-config-db-password

# Lab DB remains local by default. It is an editable import/runtime test source,
# not the canonical metadata store.
LAB_DB_ROOT_PASSWORD=change-this-lab-root-password
LAB_DB_NAME=lab_app
LAB_DB_USER=lab_app
LAB_DB_PASSWORD=change-this-lab-password

MAILDEV_SMTP_PORT=1025
MAILDEV_HTTP_PORT=1080
